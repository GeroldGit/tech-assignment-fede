{
  "info": {
    "name": "Pet Manager API",
    "_postman_id": "e8f4f6ee-8b1e-4d5f-b875-b5e95d6d2051",
    "description": "Collection to quickly test Pet Manager CRUD APIs with Basic Auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Pet (ADMIN)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (json && json.id) {",
              "    pm.collectionVariables.set('petId', String(json.id));",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "{{adminUser}}",
              "type": "string"
            },
            {
              "key": "password",
              "value": "{{adminPass}}",
              "type": "string"
            }
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Buddy\",\n  \"species\": \"Dog\",\n  \"age\": 3,\n  \"ownerName\": \"John Doe\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/pets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "pets"
          ]
        }
      }
    },
